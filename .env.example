# ─── Tiny Therapist Companion — Environment Variables ───
# Copy this file to .env and adjust values as needed.
# On HuggingFace Spaces, set these as Space Secrets instead.

# ── Backend Selection ──────────────────────────────────────
# llama_cpp  →  Use llama-cpp-python (GGUF quantised model, fast on CPU)
# transformers →  Use HuggingFace transformers + torch (full-precision, needs more RAM)
BACKEND=llama_cpp

# ── Model Identifiers ─────────────────────────────────────
# HuggingFace model ID for the transformers backend
MODEL_ID=nvidia/Llama-3.1-Nemotron-Nano-4B-v1.1

# GGUF repo and filename for the llama_cpp backend
GGUF_MODEL_ID=bartowski/Llama-3.1-Nemotron-Nano-4B-v1.1-GGUF
GGUF_FILENAME=*Q4_K_M.gguf

# ── HuggingFace Space Flag ────────────────────────────────
# Set to "yes" when running inside a HuggingFace Space
# (adjusts port binding, caching paths, etc.)
HF_SPACE=yes